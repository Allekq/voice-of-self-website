---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Voice of Self legal hub and public website.",
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const homeHref = baseUrl;
const isHomePage = Astro.url.pathname === baseUrl;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class:list={[isHomePage ? "is-home" : "is-legal"]}>
    <div class="site-backdrop" aria-hidden="true">
      <div class="site-backdrop__orb site-backdrop__orb--gold"></div>
      <div class="site-backdrop__orb site-backdrop__orb--blue"></div>
      <div class="site-backdrop__grid"></div>
    </div>

    {!isHomePage && (
      <header class="site-header">
        <a class="site-header__home-link" href={homeHref}>Voice of Self</a>
      </header>
    )}

    <main class="site-frame">
      {isHomePage ? <slot /> : <article class="legal-article"><slot /></article>}
    </main>
  </body>
</html>
