---
import SiteFooter from "../components/landing/sections/SiteFooter.astro";
import ActionButton from "../components/landing/ui/ActionButton.astro";
import { siteConfig } from "../config/site";
import SiteLayout from "../layouts/SiteLayout.astro";
import "../styles/landing.css";
import "../styles/waitlist-guide.css";
---

<SiteLayout
  title="How to Join the Waitlist"
  description="Choose how you want to join the Voice of Self waitlist."
  pageType="content"
>
  <div class="waitlist-guide">
    <section class="waitlist-guide__hero landing-surface">
      <p class="waitlist-guide__eyebrow">How to join</p>
      <h1 class="waitlist-guide__title">Choose the waitlist method that feels easiest.</h1>
      <p class="waitlist-guide__lead">
        Use whichever option feels simplest. The waitlist page keeps the current signup route and
        the email options in one place.
      </p>

      <div class="waitlist-guide__actions">
        <ActionButton href={siteConfig.waitlistFormHref}>Join the waitlist</ActionButton>
        <ActionButton href={siteConfig.waitlistMailtoHref} variant="secondary">
          Open your email app
        </ActionButton>
        <ActionButton href={siteConfig.waitlistGmailHref} variant="secondary">
          Open Gmail in browser
        </ActionButton>
      </div>

      <p class="waitlist-guide__note">
        Email fallback goes to <strong>{siteConfig.waitlistEmail}</strong>.
      </p>
    </section>
  </div>

  <SiteFooter />
</SiteLayout>
