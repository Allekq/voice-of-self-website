---
import SiteFooter from "../components/landing/sections/SiteFooter.astro";
import ActionButton from "../components/landing/ui/ActionButton.astro";
import { siteConfig } from "../config/site";
import SiteLayout from "../layouts/SiteLayout.astro";
import "../styles/landing.css";
import "../styles/waitlist-guide.css";
---

<SiteLayout
  title="How to join the waitlist"
  description="A browser-safe guide for joining the Voice of Self waitlist."
  pageType="content"
>
  <div class="waitlist-guide">
    <section class="waitlist-guide__hero landing-surface">
      <p class="waitlist-guide__eyebrow">Desktop join options</p>
      <h1 class="waitlist-guide__title">Join the Voice of Self waitlist from any browser.</h1>
      <p class="waitlist-guide__lead">
        On phones and tablets, the main waitlist button usually opens an email draft right away. On
        desktop browsers, Gmail in the browser is the default because system mail handling varies,
        and this page keeps both options plus a copy-ready fallback.
      </p>

      <div class="waitlist-guide__actions">
        <ActionButton href={siteConfig.waitlistGmailHref}>Open Gmail in browser</ActionButton>
        <ActionButton href={siteConfig.waitlistMailtoHref} variant="secondary">
          Open your email app
        </ActionButton>
      </div>

      <p class="waitlist-guide__note">
        Gmail is the most reliable desktop path. If you prefer Apple Mail or another client, try
        your email app instead.
      </p>

      <p class="waitlist-guide__note">
        If those options do not open cleanly, copy the email address and the short draft below.
      </p>
    </section>

    <div class="waitlist-guide__grid">
      <section class="waitlist-guide__card landing-surface">
        <div class="waitlist-guide__card-head">
          <div class="waitlist-guide__detail waitlist-guide__detail--email">
            <p class="waitlist-guide__detail-label">Send it to</p>
            <p class="waitlist-guide__detail-value waitlist-guide__detail-value--email">
              {siteConfig.waitlistEmail}
            </p>
          </div>
          <button class="waitlist-guide__copy" type="button" data-copy-value={siteConfig.waitlistEmail}>
            Copy email
          </button>
        </div>

        <div class="waitlist-guide__detail">
          <p class="waitlist-guide__detail-label">Suggested subject</p>
          <p class="waitlist-guide__pill">{siteConfig.waitlistDraft.subject}</p>
        </div>

        <p class="waitlist-guide__body">
          The Gmail button above opens a prefilled compose window in the browser instead of relying
          on your system mail settings.
        </p>
      </section>

      <section class="waitlist-guide__card landing-surface">
        <p class="waitlist-guide__kicker">Keep it simple</p>
        <h2 class="waitlist-guide__card-title">Your name is enough. Everything else is optional.</h2>

        <p class="waitlist-guide__body">
          The draft is intentionally short so joining the waitlist feels low-friction. If you want,
          you can send it with just your name and nothing more.
        </p>
      </section>
    </div>

    <section class="waitlist-guide__card landing-surface">
      <div class="waitlist-guide__card-head">
        <div>
          <p class="waitlist-guide__kicker">Ready-made draft</p>
          <h2 class="waitlist-guide__card-title">Send this as-is or personalize it.</h2>
        </div>
        <button class="waitlist-guide__copy" type="button" data-copy-value={siteConfig.waitlistDraft.body}>
          Copy draft
        </button>
      </div>

      <pre class="waitlist-guide__template">{siteConfig.waitlistDraft.body}</pre>
    </section>
  </div>

  <SiteFooter />

  <script>
    import "../scripts/waitlist-guide/copy-buttons";
  </script>
</SiteLayout>
