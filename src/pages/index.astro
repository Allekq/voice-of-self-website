---
import "../styles/landing.css";
import landingScript from "../scripts/landing/init.ts?url";
import HomePageOrchestrator from "../components/landing/orchestrator/HomePageOrchestrator.astro";
import { siteConfig } from "../config/site";
import SiteLayout from "../layouts/SiteLayout.astro";
import SiteFooter from "../components/landing/sections/SiteFooter.astro";
---

<SiteLayout title={siteConfig.homeTitle} description={siteConfig.defaultDescription}>
  <HomePageOrchestrator />
  <SiteFooter />

  <script is:inline type="module" src={landingScript}></script>
</SiteLayout>
