---
import type { StepItem } from "../../types";

interface Props {
  steps: StepItem[];
}

const { steps } = Astro.props as Props;
---

<div class="steps-desktop" data-step-showcase-desktop data-reveal>
  <div class="steps-desktop__track" aria-hidden="true">
    <div class="steps-desktop__line" data-step-showcase-desktop-line></div>
    <div class="steps-desktop__line-fill" data-step-showcase-desktop-fill></div>
    <div class="steps-desktop__progress" data-step-showcase-desktop-progress></div>
  </div>

  <div class="steps-desktop__grid">
    {steps.map((step, index) => (
      <article
        class="step-card step-card--desktop"
        data-step-showcase-desktop-card
        data-step-index={index}
      >
        <div class="step-card__node" data-step-showcase-desktop-node>{index + 1}</div>
        <div class="step-card__content">
          <h3 class="step-card__title">{step.title}</h3>
          <p class="step-card__body">{step.description}</p>
        </div>
      </article>
    ))}
  </div>
</div>
