---
import type { DriftConfig } from "../types";

interface Props {
  className?: string;
}

interface BackdropLayer {
  tone: "gold" | "blue" | "coral";
  drift: DriftConfig;
}

const { className } = Astro.props as Props;

const layers: BackdropLayer[] = [
  {
    tone: "gold",
    drift: { seed: 7, amplitudeX: 13, amplitudeY: 10, speed: 0.34 },
  },
  {
    tone: "blue",
    drift: { seed: 19, amplitudeX: 11, amplitudeY: 12, speed: 0.42 },
  },
  {
    tone: "coral",
    drift: { seed: 31, amplitudeX: 14, amplitudeY: 9, speed: 0.38 },
  },
];
---

<div class:list={["animated-phone-backdrop", className]} aria-hidden="true">
  {layers.map(({ tone, drift }) => (
    <span
      class:list={["animated-phone-backdrop__orb", `animated-phone-backdrop__orb--${tone}`]}
      data-noise-drift
      data-drift-seed={drift.seed}
      data-drift-amplitude-x={drift.amplitudeX}
      data-drift-amplitude-y={drift.amplitudeY}
      data-drift-speed={drift.speed}
    ></span>
  ))}
</div>
