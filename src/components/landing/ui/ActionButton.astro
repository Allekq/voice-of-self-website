---
import { isExternalHref } from "../../../lib/paths";

interface Props {
  href: string;
  variant?: "primary" | "secondary";
  className?: string;
  label?: string;
}

const { href, variant = "primary", className, label } = Astro.props as Props;
const rel =
  isExternalHref(href) && !href.startsWith("mailto:") && !href.startsWith("tel:") && !href.startsWith("#")
    ? "noreferrer"
    : undefined;
---

<a class:list={["landing-button", `landing-button--${variant}`, className]} href={href} rel={rel}>
  <slot>{label}</slot>
</a>
