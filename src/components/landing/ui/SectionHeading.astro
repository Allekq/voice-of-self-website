---
interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  align?: "left" | "center";
  className?: string;
}

const { eyebrow, title, body, align = "left", className } = Astro.props as Props;
---

<div class:list={["section-heading", `section-heading--${align}`, className]} data-reveal>
  {eyebrow && <p class="section-heading__eyebrow">{eyebrow}</p>}
  <h2 class="section-heading__title">{title}</h2>
  {body && <p class="section-heading__body">{body}</p>}
</div>
