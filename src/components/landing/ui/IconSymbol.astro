---
import type { IconName } from "../types";

interface Props {
  name: IconName;
  size?: number;
  strokeWidth?: number;
  className?: string;
}

const { name, size = 20, strokeWidth = 1.8, className } = Astro.props as Props;
const fill = name === "star" ? "currentColor" : "none";
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={fill}
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {name === "mic" && (
    <>
      <path d="M12 2a3 3 0 0 0-3 3v6a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path>
      <path d="M19 10v1a7 7 0 0 1-14 0v-1"></path>
      <path d="M12 18v4"></path>
      <path d="M8 22h8"></path>
    </>
  )}
  {name === "wave" && <path d="M2 12h4l3 8 6-16 3 8h4"></path>}
  {name === "check" && <path d="m5 13 4 4L19 7"></path>}
  {name === "star" && <path d="m12 2 2.6 6.9 7.4.3-5.8 4.5 2 7.1L12 16.7 5.8 20.8l2-7.1L2 9.2l7.4-.3Z"></path>}
  {name === "clock" && (
    <>
      <circle cx="12" cy="12" r="9"></circle>
      <path d="M12 7v5l3 3"></path>
    </>
  )}
  {name === "gear" && (
    <>
      <circle cx="12" cy="12" r="2.7"></circle>
      <path d="M12 2.5v2.2M12 19.3v2.2M4.7 4.7l1.5 1.5M17.8 17.8l1.5 1.5M2.5 12h2.2M19.3 12h2.2M4.7 19.3l1.5-1.5M17.8 6.2l1.5-1.5"></path>
    </>
  )}
  {name === "sparkle" && (
    <>
      <path d="m12 3 1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5Z"></path>
      <path d="M19 4v2"></path>
      <path d="M20 5h-2"></path>
      <path d="M5 17v2"></path>
      <path d="M6 18H4"></path>
    </>
  )}
  {name === "close" && (
    <>
      <path d="M6 6 18 18"></path>
      <path d="M18 6 6 18"></path>
    </>
  )}
  {name === "orbit" && (
    <>
      <circle cx="12" cy="12" r="3.5"></circle>
      <path d="M4 12a8 8 0 0 1 8-8"></path>
      <path d="M20 12a8 8 0 0 1-8 8"></path>
    </>
  )}
</svg>
