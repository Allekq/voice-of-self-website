---
import type { FeatureItem } from "../types";
import IconSymbol from "./IconSymbol.astro";

type Props = FeatureItem;
const { icon, title, description } = Astro.props as Props;
---

<article class="feature-card landing-surface" data-reveal>
  <div class="feature-card__icon">
    <IconSymbol name={icon} size={22} />
  </div>
  <h3 class="feature-card__title">{title}</h3>
  <p class="feature-card__body">{description}</p>
</article>
