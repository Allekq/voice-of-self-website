---
import type { StepItem } from "../../types";

interface Props {
  steps: StepItem[];
}

const { steps } = Astro.props as Props;
---

<div class="steps-mobile" data-steps-mobile data-reveal>
  <div class="steps-mobile__track" aria-hidden="true">
    <div class="steps-mobile__line" data-mobile-line></div>
    <div class="steps-mobile__line-fill" data-mobile-fill></div>
    <div class="steps-mobile__progress" data-mobile-progress></div>
  </div>

  <div class="steps-mobile__list">
    {steps.map((step, index) => (
      <article class="step-card step-card--mobile" data-mobile-step data-step-index={index}>
        <div class="step-card__node step-card__node--mobile" data-mobile-step-node>{index + 1}</div>
        <div class="step-card__content">
          <h3 class="step-card__title">{step.title}</h3>
          <p class="step-card__body">{step.description}</p>
        </div>
      </article>
    ))}
  </div>
</div>
