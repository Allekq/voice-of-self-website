---
import type { StepItem } from "../../types";

interface Props {
  steps: StepItem[];
}

const { steps } = Astro.props as Props;
---

<div class="steps-desktop" data-steps-desktop data-reveal>
  <div class="steps-desktop__track" aria-hidden="true">
    <div class="steps-desktop__line" data-steps-line></div>
    <div class="steps-desktop__line-fill" data-steps-fill></div>
    <div class="steps-desktop__progress" data-steps-progress></div>
  </div>

  <div class="steps-desktop__grid">
    {steps.map((step, index) => (
      <article class="step-card step-card--desktop" data-step-card data-step-index={index}>
        <div class="step-card__node" data-step-node>{index + 1}</div>
        <h3 class="step-card__title">{step.title}</h3>
        <p class="step-card__body">{step.description}</p>
      </article>
    ))}
  </div>
</div>
