---
import { siteConfig } from "../../../config/site";
import type { NavPillLink } from "../types";
import NavPillItem from "../ui/NavPillItem.astro";
import NavPills from "../ui/NavPills.astro";
import WaitlistButton from "../ui/WaitlistButton.astro";

interface Props {
  tabs: NavPillLink[];
}

const { tabs } = Astro.props as Props;
---

<header class="landing-header" data-landing-header>
  <div class="landing-header__bar">
    <a class="landing-brand" href="#main">{siteConfig.name}</a>

    <div class="landing-header__desktop-nav">
      <NavPills label="Primary">
        {tabs.map((item, index) => <NavPillItem {...item} active={index === 0} />)}
      </NavPills>
    </div>

    <WaitlistButton className="landing-header__cta" />
  </div>

  <div class="landing-header__mobile-nav">
    <NavPills label="Sections">
      {tabs.map((item, index) => <NavPillItem {...item} active={index === 0} />)}
    </NavPills>
  </div>
</header>
