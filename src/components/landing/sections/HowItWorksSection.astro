---
import HowItWorksDesktop from "./how-it-works/HowItWorksDesktop.astro";
import HowItWorksMobile from "./how-it-works/HowItWorksMobile.astro";
import { steps } from "./how-it-works/steps.data";
import SectionHeading from "../ui/SectionHeading.astro";
import SectionShell from "../ui/SectionShell.astro";
---

<SectionShell id="how-it-works" className="steps-section">
  <SectionHeading
    eyebrow="How it works"
    title="Three steps. No effort."
    align="center"
  />

  <HowItWorksDesktop steps={steps} />
  <HowItWorksMobile steps={steps} />
</SectionShell>
