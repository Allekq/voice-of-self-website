---
import SectionHeading from "../ui/SectionHeading.astro";
import SectionShell from "../ui/SectionShell.astro";
---

<SectionShell id="why-it-matters" tone="muted" className="why-section">
  <SectionHeading
    eyebrow="Why it matters"
    title="Most people are not failing to grow. They are failing to notice that they've grown."
    body="We remember stress, fear, and unresolved problems much more vividly than the moment they quietly stop controlling us. Voice of Self helps restore that missing context and makes personal change easier to see."
    align="center"
    className="why-section__heading"
  />
</SectionShell>
