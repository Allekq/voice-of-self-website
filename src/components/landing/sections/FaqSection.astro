---
import { faqEntries } from "./faq.data";
import FaqList from "../ui/FaqList.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import SectionShell from "../ui/SectionShell.astro";
---

<SectionShell id="faq" tone="muted" className="faq-section">
  <SectionHeading
    eyebrow="FAQ"
    title="Questions you might have"
    align="center"
  />

  <FaqList items={faqEntries} />
</SectionShell>
