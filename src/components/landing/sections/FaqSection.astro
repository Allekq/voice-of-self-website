---
import { faqEntries } from "./faq.data";
import FaqItem from "../ui/FaqItem.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import SectionShell from "../ui/SectionShell.astro";
---

<SectionShell id="faq" tone="muted" className="faq-section">
  <SectionHeading
    eyebrow="FAQ"
    title="Questions you might have"
    align="center"
  />

  <div class="faq-grid">
    {faqEntries.map((entry, index) => (
      <FaqItem
        id={`faq-${index + 1}`}
        question={entry.question}
        answer={entry.answer}
        defaultOpen={index === 0}
      />
    ))}
  </div>
</SectionShell>
