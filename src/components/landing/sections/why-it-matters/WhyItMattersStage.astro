---
import {
  whyItMattersAnxietyLabels,
  whyItMattersPreparedLabels,
  whyItMattersRelics,
  whyItMattersSolvedGoal,
} from "./why-it-matters.data";
import WhyRelicCard from "./WhyRelicCard.astro";
import WhyStageMetric from "./WhyStageMetric.astro";
---

<div class="why-growth-stage" aria-hidden="true" data-surface-depth data-why-stage>
  <div class="why-growth-stage__glow why-growth-stage__glow--gold"></div>
  <div class="why-growth-stage__glow why-growth-stage__glow--blue"></div>

  <div class="why-growth-stage__labels">
    <span>Then</span>
    <span>Repeated fears becoming readable proof</span>
    <span>Now</span>
  </div>

  <div class="why-growth-stage__deck">
    <div class="why-growth-stage__deck-backdrop"></div>
    <div class="why-growth-stage__scan"></div>

    {whyItMattersRelics.map((relic) => <WhyRelicCard relic={relic} />)}
  </div>

  <div class="why-growth-stage__timeline">
    <span>Then</span>
    <div class="why-growth-stage__timeline-track">
      <div class="why-growth-stage__timeline-fill"></div>
      <div class="why-growth-stage__timeline-marker"></div>
      <div class="why-growth-stage__timeline-ticks">
        {Array.from({ length: whyItMattersSolvedGoal }).map(() => <span></span>)}
      </div>
    </div>
    <span>Now</span>
  </div>

  <div class="why-growth-stage__metrics">
    <WhyStageMetric label="Worries solved">
      <span class="why-growth-stage__metric-value" data-why-solved-count>0</span>
    </WhyStageMetric>

    <WhyStageMetric label="Anxiety signal">
      <div class="why-growth-stage__signal-bars">
        {Array.from({ length: whyItMattersSolvedGoal }).map((_, index) => (
          <span
            class="why-growth-stage__signal-bar"
            data-why-anxiety-bar
            style={`--signal-index:${index + 1};`}
          ></span>
        ))}
      </div>
      <p class="why-growth-stage__metric-note" data-why-anxiety-label>
        {whyItMattersAnxietyLabels[0]}
      </p>
    </WhyStageMetric>

    <WhyStageMetric label="Feeling prepared">
      <div class="why-growth-stage__prepared-bars">
        {Array.from({ length: whyItMattersSolvedGoal }).map((_, index) => (
          <span
            class="why-growth-stage__prepared-bar"
            data-why-prepared-bar
            style={`--prepared-index:${index + 1};`}
          ></span>
        ))}
      </div>
      <p class="why-growth-stage__metric-note" data-why-prepared-label>
        {whyItMattersPreparedLabels[0]}
      </p>
    </WhyStageMetric>
  </div>
</div>
