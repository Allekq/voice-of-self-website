---
interface Props {
  title: string;
  dateLabel: string;
  summary: string;
  insight?: string;
  compact?: boolean;
}

const { title, dateLabel, summary, insight, compact = false } = Astro.props as Props;
---

<article class:list={["mock-relic-card", compact && "mock-relic-card--compact"]}>
  <div class="mock-relic-card__row">
    <p class="mock-relic-card__title">{title}</p>
    <p class="mock-relic-card__date">{dateLabel}</p>
  </div>
  <p class="mock-relic-card__summary">{summary}</p>
  {insight && (
    <div class="mock-relic-card__insight">
      <p>{insight}</p>
    </div>
  )}
</article>
