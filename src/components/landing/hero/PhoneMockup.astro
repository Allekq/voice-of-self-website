---
import IconSymbol from "../ui/IconSymbol.astro";
import AnimatedPhoneBackdrop from "../ui/AnimatedPhoneBackdrop.astro";
import FloatingFeatureCard from "./FloatingFeatureCard.astro";
import MockPhoneFrame from "./MockPhoneFrame.astro";
import MockTabBar from "./MockTabBar.astro";

const tabItems = [
  { icon: "orbit", label: "Present" },
  { icon: "clock", label: "Past" },
  { icon: "sparkle", label: "Relics" },
] as const;
---

<div class="phone-mockup" data-hero-parallax-root>
  <FloatingFeatureCard
    icon="mic"
    title="Voice reflection"
    subtitle="Capture it in the moment"
    positionClass="floating-feature-card--top-left"
  />
  <FloatingFeatureCard
    icon="wave"
    title="Patterns surfaced"
    subtitle="Analysis turns noise into signals"
    positionClass="floating-feature-card--bottom-left"
  />
  <FloatingFeatureCard
    icon="check"
    title="Growth preserved"
    subtitle="Meaningful progress becomes relics"
    positionClass="floating-feature-card--right"
  />

  <div
    class="phone-mockup__device-layer"
    data-hero-parallax-layer
    data-hero-depth="0.62"
    data-hero-scroll-depth="0.72"
    data-hero-rotate-factor="2.6"
  >
    <MockPhoneFrame>
      <div class="phone-screen">
        <AnimatedPhoneBackdrop className="phone-screen__backdrop" />

        <div class="phone-screen__content">
          <div class="phone-screen__status-bar" aria-hidden="true">
            <span class="phone-screen__status-time">23:24</span>
            <div class="phone-screen__status-icons">
              <span class="phone-screen__status-signal">
                <span></span>
                <span></span>
                <span></span>
                <span></span>
              </span>
              <span class="phone-screen__status-battery">
                <span></span>
              </span>
            </div>
          </div>

          <div class="phone-screen__top">
            <div class="phone-screen__toolbar">
              <div class="phone-screen__settings">
                <IconSymbol name="gear" size={14} />
              </div>
            </div>

            <div class="phone-screen__heading">
              <span class="phone-screen__heading-icon">
                <IconSymbol name="orbit" size={14} />
              </span>
              <h3>Present</h3>
            </div>
            <p class="phone-screen__subcopy">
              Capture what&apos;s on your mind right now
            </p>

            <div class="phone-screen__analysis">
              <div class="phone-screen__analysis-copy">
                <h4>Analysis Completed</h4>
                <p>Your newest relic is ready.</p>
              </div>

              <article class="phone-insight-card phone-insight-card--summary">
                <p class="phone-insight-card__eyebrow">Today&apos;s Reflection</p>
                <p class="phone-insight-card__body">
                  You kept turning the pressure around licensing into a study rhythm you can
                  actually trust, and that steadiness is starting to show.
                </p>
              </article>

              <article class="phone-insight-card phone-insight-card--relic">
                <div class="phone-insight-card__header">
                  <div class="phone-insight-card__title-block">
                    <p class="phone-insight-card__title">Found Your Summit Rhythm</p>
                  </div>
                  <div class="phone-insight-card__meta">
                    <p class="phone-insight-card__date">Mar 19</p>
                    <span class="phone-insight-card__badge">New</span>
                  </div>
                </div>

                <p class="phone-insight-card__worry">
                  Feeling pulled in every direction by exam prep and the fear of falling behind.
                </p>

                <div class="phone-insight-card__growth">
                  <p>
                    You are building calm, repeatable preparation instead of letting pressure set
                    the pace.
                  </p>
                </div>
              </article>
            </div>
          </div>

          <div class="phone-screen__bottom">
            <div class="phone-screen__done" aria-hidden="true"><span>Done</span></div>

            <MockTabBar items={tabItems} activeLabel="Present" />
          </div>
        </div>
      </div>
    </MockPhoneFrame>
  </div>
</div>
