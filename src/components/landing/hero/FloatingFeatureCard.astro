---
import type { DriftConfig, IconName } from "../types";
import IconSymbol from "../ui/IconSymbol.astro";

interface Props {
  icon: IconName;
  title: string;
  subtitle: string;
  positionClass: string;
  drift: DriftConfig;
  depth: number;
}

const { icon, title, subtitle, positionClass, drift, depth } = Astro.props as Props;
---

<div
  class:list={["floating-feature-card", positionClass]}
  data-noise-drift
  data-hero-parallax-layer
  data-hero-depth={depth}
  data-drift-seed={drift.seed}
  data-drift-amplitude-x={drift.amplitudeX}
  data-drift-amplitude-y={drift.amplitudeY}
  data-drift-speed={drift.speed}
>
  <div class="floating-feature-card__icon">
    <IconSymbol name={icon} size={16} />
  </div>
  <div class="floating-feature-card__copy">
    <p class="floating-feature-card__title">{title}</p>
    <p class="floating-feature-card__subtitle">{subtitle}</p>
  </div>
</div>
