---
import type { IconName } from "../types";
import IconSymbol from "../ui/IconSymbol.astro";

interface Props {
  icon: IconName;
  title: string;
  subtitle: string;
  positionClass: string;
}

const { icon, title, subtitle, positionClass } = Astro.props as Props;
---

<div class:list={["floating-feature-card", positionClass]}>
  <div class="floating-feature-card__inner">
    <div class="floating-feature-card__icon">
      <IconSymbol name={icon} size={16} />
    </div>
    <div class="floating-feature-card__copy">
      <p class="floating-feature-card__title">{title}</p>
      <p class="floating-feature-card__subtitle">{subtitle}</p>
    </div>
  </div>
</div>
